{
  "name": "xhs-ai-video-maker",
  "version": "0.1.0",
  "private": true,
  "description": "A Remotion-based vertical video generator for Xiaohongshu AI learning-log videos.",
  "scripts": {
    "dev": "remotion studio",
    "render": "remotion render src/index.ts AiLearningVideo out/episode-001.mp4",
